{
  "version": 2,
  "framework": null,
  "buildCommand": "",
  "outputDirectory": ".",
  "functions": {
    "api/index.php": {
      "runtime": "vercel-php@0.9.0"
    }
  },
  "routes": [
    {
      "src": "/(assets/.*)",
      "dest": "/public/$1"
    },
    {
      "src": "/(.*\\.(css|js|png|jpg|jpeg|gif|svg|webp|ico|woff|woff2|ttf|eot))",
      "dest": "/public/$1"
    },
    { "src": "/pembeli/produk.php", "dest": "/produk", "status": 301 },
    { "src": "/pembeli/kategori_pembeli.php", "dest": "/kategori", "status": 301 },
    { "src": "/pembeli/tentang_pembeli.php", "dest": "/tentang", "status": 301 },
    { "src": "/pembeli/bantuan_pembeli.php", "dest": "/bantuan", "status": 301 },
    { "src": "/pembeli/cara_membersihkan_sepatu.php", "dest": "/cara-membersihkan", "status": 301 },
    { "src": "/pembeli/detail_produk.php", "dest": "/detail-produk", "status": 301 },
    { "src": "/pembeli/keranjang_pembeli.php", "dest": "/keranjang", "status": 301 },
    { "src": "/pembeli/akun_pembeli.php", "dest": "/akun", "status": 301 },
    { "src": "/pembeli/pesanan_pembeli.php", "dest": "/pesanan", "status": 301 },
    { "src": "/pembeli/wishlist.php", "dest": "/wishlist", "status": 301 },
    { "src": "/wishlist.php", "dest": "/wishlist", "status": 301 },
    { "src": "/pembeli/chat.php", "dest": "/chat", "status": 301 },
    { "src": "/chat.php", "dest": "/chat", "status": 301 },
    { "src": "/pembeli/checkout_pembeli.php", "dest": "/checkout", "status": 301 },
    { "src": "/pembeli/lapor_masalah.php", "dest": "/lapor-masalah", "status": 301 },
    { "src": "/pembeli/beranda_pembeli.php", "dest": "/", "status": 301 },
    { "src": "/pembeli/detail_pesanan_pembeli.php", "dest": "/detail-pesanan", "status": 301 },
    { "src": "/pembeli/keranjang_tambah.php", "dest": "/keranjang-tambah", "status": 301 },
    { "src": "/pembeli/chat.php", "dest": "/chat", "status": 301 },
    { "src": "/favicon.ico", "dest": "/public/assets/images/easenikers.png" },
    {
      "src": "/(.*)",
      "dest": "/api/index.php"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "geolocation=(), microphone=(), camera=(), notifications=(self)"
        }
      ]
    }
  ],
  "env": {
    "APP_ENV": "production",
    "URL_APLIKASI": "https://www.easenikers.shop",
    "PAKASIR_PROJECT_SLUG": "easenikers",
    "PAKASIR_API_KEY": "4eXA7A6IcbrTSrMjqPktZuJlhi64NwP1",
    "PAKASIR_MODE": "sandbox",
    "PAKASIR_METODE_DEFAULT": "qris"
  }
}
